# Local Ollama (default)
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma3:4b

# OpenAI example
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# --- Scalability knobs ---
MAX_DOWNLOAD_WORKERS=5      # concurrent PDF downloads / Prefect task runner workers
MAX_LLM_CONCURRENCY=3       # concurrent LLM calls (describe/translate), rate-limits the backend
MAX_PAGES=1                 # listing pages to scrape (each ~10 books)
PAGE_SIZE=10                # entries per listing page
MIN_BOOKS=12               # keep paginating until at least this many unique books are found
MAX_BOOKS=0
# --- Versioning ---
# Optional: pin a run id (e.g. for CI/reruns). If unset, a timestamp-based id
# is generated automatically and outputs go to data/runs/<run_id>/.
# RUN_ID=my-fixed-run-id

# --- Prefect ---
# Uses Prefect's local/ephemeral mode by default (no external server needed).
PREFECT_LOGGING_LEVEL=INFO
# set a timeout for the ephemeral Prefect server to start up (in seconds).
PREFECT_SERVER_EPHEMERAL_STARTUP_TIMEOUT_SECONDS=60

# Disable Prefect's analytics (telemetry) to avoid sending usage data to Prefect.
PREFECT_SERVER_ANALYTICS_ENABLED=false
